#include <bits/stdc++.h>
using namespace std;
int main(){
    int t;
    cin>>t;
    for(int i=0;i<t;i++){
        int arr[4];
        for(int j=0;j<4;j++){
            cin>>arr[j];
        }
        int a=arr[0];
        int b=1;
        for(int j=0;j<4;j++){
            if(arr[j]!=a){
                b=0;
                break;
            }
        }
        if(b==1){
            cout<<"Yes"<<endl;
        }
        else{
            cout<<"No"<<endl;
        }
    }
}